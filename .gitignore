# Visual Studio 2015 user specific files
.vs/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
.vsconfig

# Precompiled Assets
SourceArt/**/*.png
SourceArt/**/*.tga

# Binary Files
Binaries/*
Plugins/**/Binaries/*

# Builds
Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Build/**/*.ico

# Built data for maps
*_BuiltData.uasset

# Configuration files generated by the Editor
Saved/*

# Compiled source files for the engine to use
Intermediate/*
Plugins/**/Intermediate/*

# Cache files for the editor to use
DerivedDataCache/*
.DS_Store
**/.DS_Store

# ── GT-Caliber-Asset submodule (defense-in-depth) ───────────────────────────
# The Fab/Epic/Cesium assets live ONLY in the private submodule mounted at
# Content/GTCaliberAssets/ (a tracked mode-160000 gitlink). They must NEVER be
# committed into this (eventually public) project tree. This rule blocks any
# stray LOOSE copies under that path from being staged into the parent repo —
# e.g. if the submodule is deinitialized and someone drops files in, or copies
# an asset out of the submodule into the parent. It matches CONTENTS under the
# path only, so the submodule gitlink itself stays tracked (gitignore never
# untracks an already-staged entry, and this pattern does not match the bare
# path "Content/GTCaliberAssets"). See docs/ASSET_HANDLING.md.
/Content/GTCaliberAssets/**
/GTCaliberAssets/**
/Fab/**
/Content/Fab/**

# Third Person Shooter Kit (paid Fab purchase, ~12GB). The source project dropped
# into the tree AND any assets migrated out of it must NEVER hit this public repo —
# licensed art belongs in the GTCaliberAssets submodule. See docs/ASSET_HANDLING.md.
/Content/ThirdPersonShooterKit/**
/Content/ThirdPersonKit/**
# GTC integration-layer Blueprints DERIVED from the paid kit (our own gamemode/
# controller/gamestate/player duplicates). Kit-derived → also kept out of public repo.
/Content/GTCShooter/**

assets/*

# ── Local-only: vendored / legacy / stranded / tooling / per-user ───────────
# These stay on disk so the editor builds, but are intentionally NOT tracked in
# this (eventually public) repo. Added 2026-06-19 to stop ~580k lines of
# untracked content showing as pending changes. See docs/ASSET_HANDLING.md.

# Vendored UE plugins (MCP bridges, Cesium, VibeUE) — not hand-edited, not shipped here
/Plugins/

# Fab "City Sample Vehicles" pack — binary .uasset car models (vendored)
/Content/CitySampleVehicles/

# Quixel/Megascans presets (Epic Content / Fab Standard License) — auto-dropped
# by the Megascans/Bridge plugin (MS_DefaultMaterial + MSTextures fallback maps).
# Licensed, not original/CC0; the EULA forbids standalone redistribution, so it
# must never land in this (eventually public) tree. Contributors claim their own
# free copy from Fab. Belongs in the GTCaliberAssets submodule otherwise.
/Content/MSPresets/

# MetaHuman characters (Common rig + Kellan/GTC heroes). Epic Licensed Content
# under the Content/Unreal EULA: source-format redistribution to third parties is
# forbidden, so the raw .uasset files must never land in this (eventually public)
# tree — even ones we authored embed Epic's RigLogic. Contributors generate their
# own free MetaHuman in-editor; ship only cooked builds. Belongs in the
# GTCaliberAssets submodule otherwise.
/Content/MetaHumans/

# Epic-licensed audio (UE EULA) — GASP Foley bank + Starter Content ambience.
# NOT original/CC0, so it must never land in this (eventually public) tree.
# Belongs in the GTCaliberAssets submodule; relocate there in-editor (reference
# fixup) once MCP/vibeue is reachable, then this ignore can be narrowed.
/Content/Audio/

# Cesium runtime settings + on-disk request cache
/Content/CesiumSettings/
cesium-request-cache.sqlite*

# Content stranded by the 5.8 -> 5.7 engine downgrade, kept for reference only
/_UE58_stranded_assets/

# Reference copy of the previous project + build trash
/Legacy_GTC/
/.build_trash_58/

# Loose vendored asset drops
/Assets/

# AI / editor tooling dirs (local agent + IDE config, not project source)
# Ignore .claude/ contents EXCEPT the shared project skills (team-tracked).
/.claude/*
!/.claude/skills/
/.codex/
/.cursor/
/.gemini/
/.vscode/
/.mcp.json

# Per-user editor settings (machine-specific)
/Config/DefaultEditorPerProjectUserSettings.ini
# Loose Content/Input — Sandbox/mobile WIP, shadowed by the CoreRedirect into the
# GTCaliberAssets submodule (the "duplicate input trap"). The input the game
# actually loads lives ONLY in the submodule; never commit loose copies here.
/Content/Input/

# Staging copies from ProjectMegaSample (Epic "Mega" anim sample: GASP/ALS/Lyra on
# SK_Mannequin) used as a RETARGET SOURCE for the soldier aim offsets. Epic Licensed
# Content — must NEVER land in this (eventually public) tree. Only the retargeted
# soldier outputs (SR_*/AO_Soldier_* on the Mixamo soldier skeleton) are kept; this
# raw Manny-skeleton staging is local-only and deleted after retarget. See
# docs/ASSET_HANDLING.md and memory gtc-mega-aim-offsets.
/Content/Characters/Mannequins/
/Content/_AnimationLibrary/
/Content/_MegaStaging/
/Content/_WeaponsPacks/
/Content/_MegaSample/
# Retargeted Mega-derived soldier pipeline (SoldierUni AO/BS/IK + source clips).
# Kept LOCAL-ONLY — the player ABP references it, but it is Epic-derived so it must
# not sit in this (public) repo. Re-build locally via Scripts/gtc_anim if missing.
/Content/_AnimPipeline/
